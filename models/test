from fastapi import FastAPI
from pydantic import BaseModel

app = FastAPI()

class ScenarioInput(BaseModel):
    saf_share: float
    hydrogen_readiness: float
    electricity_price: float
    carbon_price: float
    demand_growth: float
    concept: str

@app.get("/")
def root():
    return {"message": "Polaris API is running"}

@app.post("/run-scenario")
def run_scenario(data: ScenarioInput):
    viability = 50 + data.saf_share * 0.2 + data.hydrogen_readiness * 0.1 - data.electricity_price * 0.3
    return {
        "viability_score": round(viability, 1),
        "recommendation": "Promising" if viability > 60 else "Needs refinement"
    }